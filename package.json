{
  "name": "@codigos/service-spy",
  "version": "0.1.0",
  "description": "A debugging toolkit for server-to-server HTTP communication. Record & replay traffic, inspect requests in real-time, and trace calls with correlation IDs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest --config vitest.config.js",
    "test:lib": "vitest --config vitest.config.js",
    "test:dashboard": "vitest --config vitest.config.dashboard.js",
    "test:all": "vitest --config vitest.config.js && vitest --config vitest.config.dashboard.js",
    "dashboard:dev": "vite",
    "dashboard:build": "vite build",
    "dashboard:preview": "vite preview"
  },
  "keywords": [
    "http",
    "debug",
    "microservices",
    "tracing",
    "record-replay",
    "inspector",
    "server-to-server"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
